# Copy this file to secrets.toml and fill in your values.
# For Streamlit Cloud: paste these into the Secrets section in app settings.

[supabase]
# Project URL: Settings -> General in Supabase dashboard
# Or take project ref from browser URL: https://supabase.com/dashboard/project/<ref>
# Then URL is: https://<ref>.supabase.co
url = "https://your-project-ref.supabase.co"

# Publishable Key from Settings -> API Keys in Supabase dashboard
# (starts with sb_publishable_...)
anon_key = "sb_publishable_..."

[admin]
pin = "1234"
